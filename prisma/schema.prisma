generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------
// 1. Identity & Access Management (IAM)
// -------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles           UserRole[]
  customerProfile CustomerProfile?
  sellerProfile   Seller?
  deliveryProfile DeliveryPerson?
  warehouseStaff  WarehouseStaff?

  orders            Order[]
  reviews           Review[]
  supportTickets    SupportTicket[]
  messages          Message[]
  cart              Cart?
  wishlist          Wishlist?
  sellerApplication SellerApplication?

  // Enterprise Additions
  wallet           Wallet?
  rewardPoints     RewardPoint?
  followers        SellerFollower[]
  blogPosts        BlogPost[]
  auditLogs        AuditLog[]
  productQuestions ProductQuestion[]
  productAnswers   ProductAnswer[]

  // Security & Soft Delete
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  deletedAt        DateTime?
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique // SUPER_ADMIN, SITE_ADMIN, OFFICE_ASSISTANT, SELLER, CUSTOMER, DELIVERY
  description String?
  users       UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model CustomerProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  dob         DateTime?
  preferences Json?
  addresses   Address[]
  user        User      @relation(fields: [userId], references: [id])
}

model Address {
  id                String          @id @default(cuid())
  customerProfileId String
  street            String
  city              String
  state             String
  postalCode        String
  country           String
  isDefault         Boolean         @default(false)
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id])
  orders            Order[]
}

// -------------------------------------
// 2. Multi-Vendor & Products
// -------------------------------------

model Seller {
  id           String              @id @default(cuid())
  userId       String              @unique
  companyName  String
  gstNumber    String?
  taxId        String?
  bankDetails  Json?
  isVerified   Boolean             @default(false)
  kycStatus    String              @default("PENDING") // PENDING, APPROVED, REJECTED
  deletedAt    DateTime?
  
  user         User                @relation(fields: [userId], references: [id])
  products     Product[]
  subscription SellerSubscription?
  followers    SellerFollower[]
  sellerOrders SellerOrder[]
}

model Category {
  id       String     @id @default(cuid())
  name     String     @unique
  image    String?
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]
}

model Product {
  id              String   @id @default(cuid())
  sellerId        String
  categoryId      String
  title           String
  description     String
  basePrice       Float
  discountPercent Float    @default(0)
  images          String[]
  isPublished     Boolean  @default(true)

  // Product identity & attributes
  brand       String?
  tags        String[] // searchable keywords
  weightGrams Int? // for shipping calculations

  // Packaging dimensions (cm)
  dimLength Float?
  dimWidth  Float?
  dimHeight Float?

  // Policies
  returnPolicy String? // e.g. "7-day return"
  warrantyInfo String? // e.g. "1 year manufacturer warranty"

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller   Seller           @relation(fields: [sellerId], references: [id])
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  reviews  Review[]

  // Enterprise Product Features
  productType   String             @default("PHYSICAL") // PHYSICAL, DIGITAL, SERVICE
  attributes    ProductAttribute[]
  digitalAssets DigitalAsset[]
  questions     ProductQuestion[]
  bundledIn     BundleItem[]
  promoted      PromotedProduct?
  bundles       ProductBundle?

  deletedAt     DateTime?

  @@index([sellerId])
  @@index([categoryId])
  @@index([categoryId, isPublished])
  @@index([sellerId, createdAt])
}

model ProductVariant {
  id         String         @id @default(cuid())
  productId  String
  sku        String         @unique
  size       String?
  color      String?
  price      Float
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  wishItems  WishlistItem[]
}

model Inventory {
  id          String         @id @default(cuid())
  variantId   String
  warehouseId String
  quantity    Int            @default(0)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variantId, warehouseId])
}

// -------------------------------------
// 3. Shopping Experience
// -------------------------------------

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int            @default(1)
  cart      Cart           @relation(fields: [cartId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
}

model Wishlist {
  id     String         @id @default(cuid())
  userId String         @unique
  user   User           @relation(fields: [userId], references: [id])
  items  WishlistItem[]
}

model WishlistItem {
  id         String         @id @default(cuid())
  wishlistId String
  variantId  String
  wishlist   Wishlist       @relation(fields: [wishlistId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, variantId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  mediaUrls String[]
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// -------------------------------------
// 4. Orders & Financials
// -------------------------------------

model Order {
  id                String   @id @default(cuid())
  userId            String
  shippingAddressId String
  totalAmount       Float
  taxAmount         Float    @default(0) // CGST + SGST
  shippingFee       Float    @default(0)
  status            String   @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  shippingProvider  String?
  trackingNumber    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user                User              @relation(fields: [userId], references: [id])
  shippingAddress     Address           @relation(fields: [shippingAddressId], references: [id])
  sellerOrders        SellerOrder[]
  payments            Payment[]
  refunds             Refund[]
  trackingHistory     TrackingHistory[]
  couponId            String?
  coupon              Coupon?           @relation(fields: [couponId], references: [id])
  deliveryPersonId    String?
  deliveryPerson      DeliveryPerson?   @relation(fields: [deliveryPersonId], references: [id])
  assignedWarehouseId String?
  assignedWarehouse   Warehouse?        @relation(fields: [assignedWarehouseId], references: [id])

  @@index([userId])
  @@index([status])
}

model SellerOrder {
  id               String   @id @default(cuid())
  orderId          String
  sellerId         String
  status           String   @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  payoutStatus     String   @default("UNPAID")  // UNPAID, PAID
  shippingProvider String?
  trackingNumber   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller           Seller   @relation(fields: [sellerId], references: [id])
  items            OrderItem[]

  @@index([orderId])
  @@index([sellerId])
}

model OrderItem {
  id            String         @id @default(cuid())
  sellerOrderId String
  variantId     String
  quantity      Int
  priceAtBuy    Float
  sellerOrder   SellerOrder    @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id                String   @id @default(cuid())
  orderId           String
  method            String // RAZORPAY, COD
  razorpayOrderId   String?  @unique
  razorpayPaymentId String?  @unique
  amount            Float
  status            String   @default("PENDING") // PENDING, SUCCESS, FAILED
  createdAt         DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([status])
}

model Refund {
  id        String   @id @default(cuid())
  orderId   String
  amount    Float
  reason    String?
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// -------------------------------------
// 5. Internal Logistics & Routing
// -------------------------------------

model Warehouse {
  id              String           @id @default(cuid())
  name            String
  location        String
  pincodes        String[]
  inventory       Inventory[]
  staff           WarehouseStaff[]
  deliveryPersons DeliveryPerson[]
  orders          Order[]
}

model WarehouseStaff {
  id          String    @id @default(cuid())
  userId      String    @unique
  warehouseId String
  user        User      @relation(fields: [userId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
}

model ShippingProvider {
  id      String @id @default(cuid())
  name    String // Internal, Delhivery, BlueDart
  apiKeys Json?
}

model Vehicle {
  id             String          @id @default(cuid())
  licensePlate   String          @unique
  type           String // Truck, Van, Bike
  capacity       Float?
  deliveryPerson DeliveryPerson?
}

model DeliveryPerson {
  id          String     @id @default(cuid())
  userId      String     @unique
  vehicleId   String?    @unique
  warehouseId String?
  user        User       @relation(fields: [userId], references: [id])
  vehicle     Vehicle?   @relation(fields: [vehicleId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  routes      Route[]
  orders      Order[]
}

model Route {
  id               String   @id @default(cuid())
  deliveryPersonId String
  assignedDate     DateTime
  pathData         Json? // GeoJSON or array of coordinates
  status           String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED

  deliveryPerson DeliveryPerson @relation(fields: [deliveryPersonId], references: [id])
}

model TrackingHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String // Packed, Shipped, OutForDelivery, Delivered
  location  String?
  timestamp DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// -------------------------------------
// 6. Customer Support & Engagement
// -------------------------------------

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  conversations Conversation[]
}

model Conversation {
  id              String        @id @default(cuid())
  supportTicketId String
  ticket          SupportTicket @relation(fields: [supportTicketId], references: [id])
  messages        Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Coupon {
  id           String   @id @default(cuid())
  code         String   @unique
  discountType String // PERCENTAGE, FIXED
  discountVal  Float
  minSpend     Float?
  maxDiscount  Float?
  validUntil   DateTime
  usageLimit   Int?
  usedCount    Int      @default(0)
  orders       Order[]
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String?
  bannerImage String?
  validFrom   DateTime
  validUntil  DateTime
  isActive    Boolean  @default(true)
}

// -------------------------------------
// 7. Global Site Settings & CMS
// -------------------------------------

model SiteSetting {
  id           String  @id @default("GLOBAL")
  brandName    String  @default("Swcart")
  contactEmail String?
  contactPhone String?
  companyAddr  String?

  // Fees & Taxes
  defaultGst         Float @default(18.0)
  deliveryFee        Float @default(50.0)
  codFee             Float @default(0.0)
  freeShippingThresh Float @default(499.0)
  platformCommission Float @default(10.0) // Percentage cut the platform takes from sellers

  // API Keys (Encrypted/Hidden in production app layer)
  razorpayKeyId  String?
  razorpaySecret String?
  gmailSmtpUser  String?
  gmailSmtpPass  String?

  // Socials
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?

  autoApproveSellers Boolean @default(true)
}

model DynamicPage {
  id        String   @id @default(cuid())
  slug      String   @unique // privacy-policy, terms-of-service, etc.
  title     String
  content   String // Markdown/HTML content
  updatedAt DateTime @updatedAt
}

model FAQ {
  id         String @id @default(cuid())
  question   String
  answer     String
  orderIndex Int    @default(0)
}

model SellerApplication {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String
  gstNumber    String?
  bankDetails  Json?
  kycDocuments String[]
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

// -------------------------------------
// 8. Enterprise Marketplace Extensions
// -------------------------------------

// Customer Engagement
model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Float               @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(cuid())
  walletId  String
  amount    Float
  type      String // CREDIT, DEBIT
  reason    String?
  createdAt DateTime @default(now())
  wallet    Wallet   @relation(fields: [walletId], references: [id])
}

model RewardPoint {
  id     String @id @default(cuid())
  userId String @unique
  points Int    @default(0)
  user   User   @relation(fields: [userId], references: [id])
}

model SellerFollower {
  id        String   @id @default(cuid())
  userId    String
  sellerId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  seller    Seller   @relation(fields: [sellerId], references: [id])

  @@unique([userId, sellerId])
}

// Product Attributes & Digital Goods
model Attribute {
  id     String                  @id @default(cuid())
  name   String                  @unique // e.g., Brand, Material, Storage
  values ProductAttributeValue[]
}

model ProductAttributeValue {
  id              String             @id @default(cuid())
  attributeId     String
  value           String // e.g., Apple, Leather, 256GB
  attribute       Attribute          @relation(fields: [attributeId], references: [id])
  productMappings ProductAttribute[]
}

model ProductAttribute {
  id        String                @id @default(cuid())
  productId String
  valueId   String
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     ProductAttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@unique([productId, valueId])
}

model DigitalAsset {
  id        String  @id @default(cuid())
  productId String
  fileUrl   String
  assetType String // EBOOK, COURSE, KEY
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBundle {
  id        String       @id @default(cuid())
  productId String       @unique // The main product that represents the bundle
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  items     BundleItem[]
}

model BundleItem {
  id              String        @id @default(cuid())
  productBundleId String
  productId       String
  quantity        Int           @default(1)
  bundle          ProductBundle @relation(fields: [productBundleId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductQuestion {
  id        String          @id @default(cuid())
  productId String
  userId    String
  question  String
  createdAt DateTime        @default(now())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id])
  answers   ProductAnswer[]
}

model ProductAnswer {
  id         String          @id @default(cuid())
  questionId String
  userId     String
  answer     String
  createdAt  DateTime        @default(now())
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id])
}

// Monetization & Ads
model SubscriptionPlan {
  id       String               @id @default(cuid())
  name     String // Basic, Pro, Enterprise
  price    Float
  features Json?
  sellers  SellerSubscription[]
}

model SellerSubscription {
  id         String           @id @default(cuid())
  sellerId   String           @unique
  planId     String
  status     String // ACTIVE, EXPIRED, CANCELLED
  validUntil DateTime
  seller     Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan @relation(fields: [planId], references: [id])
}

model PromotedProduct {
  id        String   @id @default(cuid())
  productId String   @unique
  bidAmount Float
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Content & Marketing
model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model BlogPost {
  id         String       @id @default(cuid())
  title      String
  slug       String       @unique
  content    String
  authorId   String
  categoryId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  author     User         @relation(fields: [authorId], references: [id])
  category   BlogCategory @relation(fields: [categoryId], references: [id])
}

model AffiliateLink {
  id        String           @id @default(cuid())
  code      String           @unique
  userId    String
  createdAt DateTime         @default(now())
  clicks    AffiliateClick[]
}

model AffiliateClick {
  id        String        @id @default(cuid())
  linkId    String
  ipAddress String?
  createdAt DateTime      @default(now())
  link      AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

// Security
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
